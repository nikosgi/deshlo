{
  "name": "@fdb/vue",
  "version": "0.1.0",
  "description": "Vue source inspector adapter",
  "main": "build/src/index.js",
  "module": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "require": "./build/src/index.js",
      "import": "./build/src/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "clean": "rm -rf build",
    "build": "tsc -p tsconfig.json",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "vue",
    "source-map",
    "debug",
    "inspector"
  ],
  "author": "Couch Heroes",
  "license": "MIT",
  "dependencies": {
    "@couch-heroes/source-inspector-core": "0.1.0"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1"
  }
}
