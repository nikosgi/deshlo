{
  "name": "@deshlo/react",
  "version": "0.1.1",
  "description": "React source inspector runtime and bundler adapters",
  "main": "build/src/index.js",
  "module": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "require": "./build/src/index.js",
      "import": "./build/src/index.js"
    },
    "./webpack": {
      "types": "./build/src/webpack.d.ts",
      "require": "./build/src/webpack.js",
      "import": "./build/src/webpack.js"
    },
    "./vite": {
      "types": "./build/src/vite.d.ts",
      "require": "./build/src/vite.js",
      "import": "./build/src/vite.js"
    },
    "./overlay": {
      "types": "./build/src/overlay.d.ts",
      "require": "./build/src/overlay.js",
      "import": "./build/src/overlay.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "clean": "rm -rf build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "keywords": [
    "react",
    "source-map",
    "debug",
    "inspector"
  ],
  "author": "Nikos Gerontakis",
  "license": "MIT",
  "dependencies": {
    "@deshlo/core": "0.1.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "vitest": "^3.2.4"
  }
}
