{
  "name": "@deshlo/loader",
  "version": "0.1.1",
  "description": "Source inspector webpack loader runtime",
  "main": "jsx-source-loader.cjs",
  "types": "index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./jsx-source-loader.cjs",
      "default": "./jsx-source-loader.cjs"
    }
  },
  "files": [
    "jsx-source-loader.cjs",
    "index.d.ts"
  ],
  "scripts": {
    "clean": "rm -rf .build",
    "build": "node ./scripts/build-loader.mjs",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "webpack-loader",
    "source-map",
    "debug",
    "inspector"
  ],
  "author": "Nikos Gerontakis",
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "^7.28.3",
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.28.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.25.9"
  }
}
