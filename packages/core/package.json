{
  "name": "@deshlo/core",
  "version": "0.1.1",
  "description": "Shared source inspector helper/wrapper utilities and contracts",
  "main": "build/src/index.js",
  "module": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "require": "./build/src/index.js",
      "import": "./build/src/index.js"
    },
    "./annotations": {
      "types": "./build/src/annotations.d.ts",
      "require": "./build/src/annotations.js",
      "import": "./build/src/annotations.js"
    },
    "./overlay-plugin": {
      "types": "./build/src/overlay-plugin.d.ts",
      "require": "./build/src/overlay-plugin.js",
      "import": "./build/src/overlay-plugin.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "clean": "rm -rf build",
    "build": "tsc -p tsconfig.json",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "source-map",
    "debug",
    "inspector"
  ],
  "author": "Nikos Gerontakis",
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "^7.28.3",
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.28.4",
    "@deshlo/loader": "0.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1"
  }
}
