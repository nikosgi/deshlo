NEXT_PUBLIC_SOURCE_INSPECTOR=1

# GitHub browser plugin settings
NEXT_PUBLIC_SOURCE_INSPECTOR_GITHUB_TOKEN=
NEXT_PUBLIC_SOURCE_INSPECTOR_BRANCH_PREFIX=source-inspector
NEXT_PUBLIC_SOURCE_INSPECTOR_GITHUB_PATH_PREFIX=apps/next-test-app
NEXT_PUBLIC_SOURCE_INSPECTOR_HOST_CONFIG={"localhost:3000":{"apiBaseUrl":"https://api.github.com","owner":"your-org","repo":"your-repo","defaultBaseBranch":"main"}}

# Live annotations (new system)
NEXT_PUBLIC_DESHLO_ANNOTATIONS=0
NEXT_PUBLIC_DESHLO_ANNOTATIONS_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_DESHLO_ANNOTATIONS_API_KEY=
NEXT_PUBLIC_DESHLO_ANNOTATIONS_ENVIRONMENT=local
