{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "es2020"
    ],
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@deshlo/core": [
        "../../packages/core/build/src/index.d.ts"
      ],
