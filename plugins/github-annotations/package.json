{
  "name": "@deshlo/plugin-github-annotations",
  "version": "0.1.1",
  "description": "GitHub plugin logic for Deshlo live annotations",
  "main": "build/src/index.js",
  "module": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "require": "./build/src/index.js",
      "import": "./build/src/index.js"
    }
  },
  "files": ["build"],
  "scripts": {
    "clean": "rm -rf build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "keywords": ["annotations", "plugin", "github"],
  "author": "Nikos Gerontakis",
  "license": "MIT",
  "dependencies": {
    "@deshlo/core": "0.1.1",
    "@octokit/core": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "vitest": "^3.2.4"
  }
}
